---
const socialLinks = [
  {
    href: "https://www.instagram.com/radiopapote/",
    label: "Instagram",
    icon: "instagram",
    cta: "S'abonner sur Instagram",
  },
  {
    href: "https://www.youtube.com/@radiopapote-26",
    label: "YouTube",
    icon: "youtube",
    cta: "S'abonner sur YouTube",
  },
  {
    href: "https://www.radiosaintfe.com/emissions/liste/detail/radio-papote",
    label: "Radio Saint Ferréol 94.2 FM",
    icon: "radio",
    cta: "Écouter sur RSF",
  },
];
---

<aside class="main-aside bg-gradient-to-br from-avec-dark via-avec-dark to-avec-dark-light text-white mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-avec-terracotta flex items-center justify-center text-lg">
            🎙️
          </div>
          <div>
            <h2 class="font-heading font-extrabold text-xl text-white">Radio Papote</h2>
            <p class="text-xs text-avec-gray">sur Radio Saint Ferréol 94.2 FM</p>
          </div>
        </div>

        <p class="text-sm text-avec-gray-light leading-relaxed mb-6">
          Dialogue ouvert et honnête sur l'actualité locale et les enjeux démocratiques,
          avec des intervenants du territoire. Tous les 2<sup>e</sup> et 4<sup>e</sup> vendredis du mois à 21h.
        </p>

        <div class="rounded-xl overflow-hidden mb-6 bg-black/20">
          <iframe
            src="https://player.rss.com/radio-papote?theme=color&v=2"
            width="100%"
            height="393px"
            title="Radio Papote"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            scrolling="no"
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <div class="flex flex-col gap-6">
        <div>
          <h3 class="font-heading font-bold text-lg text-white mb-4">Suivez-nous</h3>
          <div class="flex flex-col gap-3">
            {socialLinks.map(({ href, label, icon, cta }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-4 p-4 rounded-xl bg-white/5 hover:bg-white/10 transition-all duration-200 border border-white/10 hover:border-white/20"
              >
                <div class="w-11 h-11 rounded-full bg-white/10 group-hover:bg-white/20 flex items-center justify-center flex-shrink-0 transition-colors">
                  {icon === "instagram" && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                    </svg>
                  )}
                  {icon === "youtube" && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                  )}
                  {icon === "radio" && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/>
                      <path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.4"/>
                      <circle cx="12" cy="12" r="2"/>
                      <path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.4"/>
                      <path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/>
                    </svg>
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-sm text-white">{label}</div>
                  <div class="text-xs text-avec-gray">{cta}</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-avec-gray group-hover:text-white group-hover:translate-x-0.5 transition-all" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.25-.75a.75.75 0 01.75-.75h3.5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0V6.31l-5.47 5.47a.75.75 0 01-1.06-1.06l5.47-5.47H12.25a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
                </svg>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-xl bg-gradient-to-r from-avec-terracotta/20 to-avec-gold/10 border border-avec-terracotta/30 p-5">
          <h3 class="font-heading font-bold text-white text-sm mb-2">
            💬 Réagissez sur Instagram
          </h3>
          <p class="text-xs text-avec-gray-light leading-relaxed mb-4">
            Vous souhaitez commenter une promesse ou partager votre avis ?
            Envoyez-nous un message ou commentez nos publications sur Instagram !
          </p>
          <div class="flex flex-wrap gap-2">
            <a
              href="https://www.instagram.com/radiopapote/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2.5 bg-avec-terracotta hover:bg-avec-terracotta-light text-white rounded-lg text-sm font-semibold transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              Commenter sur Instagram
            </a>
            <a
              href="https://www.youtube.com/@radiopapote-26?sub_confirmation=1"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2.5 bg-white/10 hover:bg-white/20 text-white rounded-lg text-sm font-semibold transition-colors border border-white/10"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              S'abonner sur YouTube
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</aside>
