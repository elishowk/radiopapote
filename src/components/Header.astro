---
const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Émissions" },
  { href: "/engagements", label: "Municipalité Crest 2026-2032" },
  { href: "mailto:contact@radiopapote.fr", label: "Contact" },
];
---

<header class="bg-white/90 backdrop-blur-md border-b border-avec-gray-light sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <a href="/" class="flex items-center gap-3 group">
        <img
          src="/logo-radiopapote.png"
          alt="Radio Papote"
          class="h-10 sm:h-12 w-auto object-contain"
        />
        <span class="font-heading font-extrabold text-lg sm:text-xl text-avec-dark hidden sm:block">
          Radio Papote
        </span>
      </a>

      <div class="flex items-center gap-3 sm:gap-4">
        <nav class="flex items-center gap-1 sm:gap-2">
          {navItems.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                "px-3 py-2 rounded-lg text-sm font-medium transition-colors",
                currentPath === href
                  ? "bg-avec-terracotta text-white"
                  : "text-avec-dark-light hover:bg-avec-warm hover:text-avec-terracotta",
              ]}
            >
              {label}
            </a>
          ))}
        </nav>

        <div class="hidden sm:flex items-center gap-2 border-l border-avec-gray-light pl-3 sm:pl-4">
          <a href="https://www.instagram.com/radiopapote/" target="_blank" rel="noopener noreferrer"
            title="Instagram" class="text-avec-dark-light hover:text-avec-terracotta transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@radiopapote-26" target="_blank" rel="noopener noreferrer"
            title="YouTube" class="text-avec-dark-light hover:text-avec-terracotta transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a href="https://www.radiosaintfe.com/emissions/liste/detail/radio-papote" target="_blank" rel="noopener noreferrer"
            title="Radio Saint Ferréol 94.2 FM" class="text-avec-dark-light hover:text-avec-terracotta transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/>
              <path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.4"/>
              <circle cx="12" cy="12" r="2"/>
              <path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.4"/>
              <path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</header>
