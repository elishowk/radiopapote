---
const year = new Date().getFullYear();
---

<footer class="bg-avec-dark text-avec-gray-light mt-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <img src="/logo-radiopapote.png" alt="Radio Papote" class="h-10 w-auto" />
          <h3 class="font-heading font-bold text-white text-lg">Radio Papote</h3>
        </div>
        <p class="text-sm text-avec-gray leading-relaxed">
          Débat politique de la vallée de la Drôme, sur Radio Saint Ferréol 94.2 FM.
          Tous les 2<sup>e</sup> et 4<sup>e</sup> vendredis du mois à 21h.
        </p>
      </div>
      <div>
        <h4 class="font-heading font-bold text-white mb-3">Liens</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://www.instagram.com/radiopapote/" target="_blank" rel="noopener noreferrer"
              class="hover:text-avec-gold transition-colors">
              Instagram @radiopapote
            </a>
          </li>
          <li>
            <a href="https://www.youtube.com/@radiopapote-26" target="_blank" rel="noopener noreferrer"
              class="hover:text-avec-gold transition-colors">
              YouTube @radiopapote-26
            </a>
          </li>
          <li>
            <a href="https://www.radiosaintfe.com/emissions/liste/detail/radio-papote" target="_blank" rel="noopener noreferrer"
              class="hover:text-avec-gold transition-colors">
              Radio Saint Ferréol 94.2 FM
            </a>
          </li>
          <li>
            <a href="/engagements" class="hover:text-avec-gold transition-colors">
              Suivi des engagements municipaux
            </a>
          </li>
          <li>
            <a href="/engagements#charte" class="hover:text-avec-gold transition-colors">
              Charte des élu·es
            </a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="font-heading font-bold text-white mb-3">Contribuer</h4>
        <p class="text-sm text-avec-gray leading-relaxed mb-4">
          Ce site est open source. Vous pouvez contribuer en signalant des avancées
          ou en proposant des améliorations.
        </p>
        <div class="flex flex-col gap-2">
          <a
            href="https://github.com/elishowk/radiopapote/issues/new"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-avec-gray hover:text-avec-gold transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor">
              <path d="M8 9.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
              <path fill-rule="evenodd" d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0z" />
            </svg>
            Signaler un problème
          </a>
          <a
            href="mailto:contact@radiopapote.fr"
            class="inline-flex items-center gap-2 text-sm text-avec-gray hover:text-avec-gold transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
              <path d="M3 4a2 2 0 00-2 2v1.161l8.441 4.221a1.25 1.25 0 001.118 0L19 7.162V6a2 2 0 00-2-2H3z" />
              <path d="M19 8.839l-7.77 3.885a2.75 2.75 0 01-2.46 0L1 8.839V14a2 2 0 002 2h14a2 2 0 002-2V8.839z" />
            </svg>
            contact@radiopapote.fr
          </a>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 mt-8 pt-6 text-center text-xs text-avec-gray">
      <p>&copy; {year} — <a href="https://radiopapote.fr" class="hover:text-avec-gold transition-colors">radiopapote.fr</a></p>
    </div>
  </div>
</footer>
