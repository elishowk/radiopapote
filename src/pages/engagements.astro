---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PromiseCard from "../components/PromiseCard.astro";
import GlobalProgress from "../components/GlobalProgress.astro";
import CharteCard from "../components/CharteCard.astro";
import VoteButton from "../components/VoteButton";

const promesses = (await getCollection("promesses")).sort(
  (a, b) => a.data.order - b.data.order,
);

const allActions = promesses.flatMap((p) => p.data.actions);
const totalActions = allActions.length;
const doneActions = allActions.filter((a) => a.done).length;
const inProgressPromises = promesses.filter(
  (p) => p.data.status === "en-cours" || p.data.status === "avancee",
).length;

const charteItems = (await getCollection("charte")).sort(
  (a, b) => a.data.order - b.data.order,
);

const renderedCharteItems = await Promise.all(
  charteItems.map(async (item) => {
    const { Content } = await render(item);
    return { ...item, Content };
  }),
);

const charteActions = charteItems.flatMap((i) => i.data.actions);
const charteDone = charteActions.filter((a) => a.done).length;
const charteTotal = charteActions.length;
const charteProgress = charteTotal > 0 ? Math.round((charteDone / charteTotal) * 100) : 0;
---

<Layout title="Suivi des engagements">
  <section class="bg-gradient-to-br from-avec-warm via-white to-avec-cream py-12 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-extrabold text-3xl sm:text-5xl text-avec-dark leading-tight mb-4">
          Suivi des engagements de la
          <span class="text-avec-terracotta">majorité municipale</span>
        </h1>
        <p class="text-lg text-avec-dark-light leading-relaxed mb-2">
          Suivez l'avancée des promesses de campagne de la
          majorité municipale de Crest, élue en mars 2026.
        </p>
        <p class="text-sm text-avec-gray">
          Ce site citoyen et collaboratif permet de suivre, commenter et voter
          pour les engagements qui vous tiennent à cœur.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-10 mb-12">
    <GlobalProgress
      total={totalActions}
      done={doneActions}
      inProgress={inProgressPromises}
    />
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="font-heading font-bold text-2xl text-avec-dark mb-8">
      Les engagements du programme
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {promesses.map((promesse) => (
        <PromiseCard
          id={promesse.id}
          title={promesse.data.title}
          icon={promesse.data.icon}
          description={promesse.data.description}
          progress={promesse.data.progress}
          status={promesse.data.status}
          actions={promesse.data.actions}
        />
      ))}
    </div>
  </section>

  <section id="charte" class="bg-gradient-to-br from-avec-warm via-white to-avec-cream py-12 border-t border-avec-gray-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-extrabold text-2xl sm:text-3xl text-avec-dark leading-tight mb-3">
        Charte des <span class="text-avec-green">élu·es</span>
      </h2>
      <p class="text-base text-avec-dark-light leading-relaxed mb-2">
        Chaque candidat·e de la majorité municipale s'est engagé·e à signer une charte
        visant à garantir un cadre de travail transparent et à restaurer
        la confiance entre élu·es et citoyen·es.
      </p>
      <p class="text-sm text-avec-gray mb-8">
        Suivez ici la mise en œuvre concrète de ces engagements.
      </p>

      <div class="bg-white rounded-2xl shadow-sm border border-avec-gray-light/60 p-6 mb-8">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-semibold text-avec-dark">Progression globale de la charte</span>
          <span class="text-sm font-bold text-avec-green">{charteProgress}%</span>
        </div>
        <div class="w-full bg-avec-gray-light rounded-full h-3 overflow-hidden">
          <div
            class="bg-avec-green h-full rounded-full transition-all duration-700"
            style={`width: ${charteProgress}%`}
          />
        </div>
        <p class="text-xs text-avec-gray mt-2">
          {charteDone} actions réalisées sur {charteTotal}
        </p>
      </div>

      <div class="space-y-6">
        {renderedCharteItems.map(({ id, data }) => (
          <div>
            <CharteCard
              id={id}
              title={data.title}
              icon={data.icon}
              description={data.description}
              status={data.status}
              actions={data.actions}
              body=""
            />
            <div class="mt-2 ml-6">
              <VoteButton client:idle id={`charte-${id}`} label="Important" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
