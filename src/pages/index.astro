---
import Layout from "../layouts/Layout.astro";
import RadioPapote from "../components/RadioPapote.astro";
---

<Layout
  title="Radio Papote"
  description="Débat politique de la vallée de la Drôme — tous les 2e et 4e vendredis du mois à 21h — 94.2FM Ferréol (Crest, 26)"
>
  <section class="w-full">
    <img
      src="/bandeau-radiopapote.jpeg"
      alt="Radio Papote — Débat politique de la vallée de la Drôme, tous les 2e et 4e vendredis du mois à 21h"
      class="w-full object-cover"
    />
  </section>

  <RadioPapote />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="rounded-2xl bg-gradient-to-br from-avec-warm to-avec-cream border border-avec-gray-light p-8 flex flex-col sm:flex-row items-start sm:items-center gap-6">
      <div class="flex-1">
        <h2 class="font-heading font-bold text-xl text-avec-dark mb-2">
          Suivi des engagements municipaux
        </h2>
        <p class="text-sm text-avec-gray leading-relaxed">
          Suivez l'avancée des promesses de campagne de la majorité municipale de Crest, élue en mars 2026.
        </p>
      </div>
      <a
        href="/engagements"
        class="flex-shrink-0 inline-flex items-center gap-2 px-5 py-3 bg-avec-terracotta hover:bg-avec-terracotta-dark text-white rounded-xl text-sm font-semibold transition-colors"
      >
        Voir les engagements
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
